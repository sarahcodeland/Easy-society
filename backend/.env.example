NODE_ENV=development
PORT=4000

# PostgreSQL — point at PgBouncer in production (transaction pooling mode),
# not directly at Postgres, once running more than a handful of API instances.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/easysociety

# Redis — used for: Socket.io adapter (cross-instance pub/sub), session/OTP
# storage, area-feed caching, rate limiting.
REDIS_URL=redis://localhost:6399

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=30d

# OTP provider: "mock" (default, logs OTP to console/Redis), "msg91", "2factor"
OTP_PROVIDER=mock
MSG91_API_KEY=
MSG91_TEMPLATE_ID=
TWOFACTOR_API_KEY=

# Object storage: "s3" or "r2"
STORAGE_PROVIDER=s3
S3_BUCKET=easysociety-media
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Only needed for Cloudflare R2 (S3-compatible endpoint)
R2_ENDPOINT=
CDN_BASE_URL=https://cdn.easysociety.app

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# OpenWeatherMap
OPENWEATHER_API_KEY=

# Google My Business (business auto-registration on Google Maps)
GOOGLE_MY_BUSINESS_CLIENT_ID=
GOOGLE_MY_BUSINESS_CLIENT_SECRET=
GOOGLE_MY_BUSINESS_REDIRECT_URI=
