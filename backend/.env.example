NODE_ENV=development
PORT=4000

# PostgreSQL — point at PgBouncer in production (transaction pooling mode),
# not directly at Postgres, once running more than a handful of API instances.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/easysociety

# Redis — used for: Socket.io adapter (cross-instance pub/sub), area-feed
# caching, rate limiting.
REDIS_URL=redis://localhost:6399

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=30d

# Object storage: "supabase" (Supabase Storage, using the service_role key)
STORAGE_PROVIDER=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=easysociety-media

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# OpenWeatherMap
OPENWEATHER_API_KEY=

# Google My Business (business auto-registration on Google Maps)
GOOGLE_MY_BUSINESS_CLIENT_ID=
GOOGLE_MY_BUSINESS_CLIENT_SECRET=
GOOGLE_MY_BUSINESS_REDIRECT_URI=
