# project directories.
# =====================================================================

# Metro / RN bundler
mobile/.metro-health-check*
mobile/*.jsbundle

# Android
mobile/android/app/build/
mobile/android/build/
mobile/android/.gradle/
mobile/android/captures/
mobile/android/local.properties
mobile/android/*.iml
mobile/android/.idea/
mobile/android/app/release/
mobile/android/app/debug/
*.keystore
!debug.keystore
*.jks

# iOS
mobile/ios/build/
mobile/ios/Pods/
mobile/ios/Podfile.lock
mobile/ios/*.xcworkspace/
mobile/ios/*.xcuserstate
mobile/ios/DerivedData/
